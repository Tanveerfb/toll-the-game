rules_version = '2';

// Each signed-in player owns exactly their own users/{uid} document.
// Guests never touch Firestore (AuthProvider only reads when signed in).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
